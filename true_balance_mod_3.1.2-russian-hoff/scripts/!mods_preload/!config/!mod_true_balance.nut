::TrueBalance <- {
    ID = "mod_true_balance",
    Version = "3.1.2",
    Name = "True Balance Mod",
    BaseProperties = null
}

::mods_registerMod(::TrueBalance.ID, ::TrueBalance.Version, ::TrueBalance.Name);

::mods_queue(::TrueBalance.ID, "mod_msu(>=1.0.0-beta.4)", function() 
{
    ::TrueBalance.Mod <- ::MSU.Class.Mod(::TrueBalance.ID, ::TrueBalance.Version, ::TrueBalance.Name);

    local page = ::TrueBalance.Mod.ModSettings.addPage("Основное");

    local champions = page.addBooleanSetting("Champions", true, "Чемпионская версия", "Именные предметы в локациях были заменены на сокровища стоимостью ~ 5000 крон, слухи в тавернах также были изменены. Шанс появления чемпионов увеличен на 5%. Именные предметы можно получить, только купив или сняв их с чемпионов.");
    champions.Data.NewCampaign <- true;
    champions.Data.NewCampaignOnly <- true;

    local greenskins = page.addBooleanSetting("GreenCastle", true, "Крепость орков", "Добавляет в игру новую легендарную локацию - 'Крепость орков', где можно сразиться за новый легендарный предмет.");
    greenskins.Data.NewCampaign <- true;
    greenskins.Data.NewCampaignOnly <- true;

    page.addBooleanSetting("Talents", false, "Детальные испытания", "[color=" + ::Const.UI.Color.NegativeValue + "]ВАЖНО: [/color]Параметр вступает в силу только при загрузке сохранения, поэтому, во избежание ошибок, не рекомендуется изменять ее непосредственно во время игры.\n\nПоказывает точную информацию о боевых характеристиках бойца при нажатии кнопки 'Испытать'. Не показывает таланты.\n\n[color=" + ::Const.UI.Color.NegativeValue + "]Не включайте, если установлены другие моды меняющие процедуру испытания наёмников, например Clever Recruiter![/color]");

    ::mods_registerJS("mod_truebalance_talents/world_town_screen_hire_dialog_module.js")
    ::mods_registerCSS("mod_truebalance_talents/css/world_town_screen_hire_dialog_module.css")

    ::include("mod_truebalance_talents/world_state");
    ::include("mod_truebalance_talents/data_helper");

    ::Const.Damage.addNewDamageType( "Saber", ::Const.Injury.SaberHead, ::Const.Injury.SaberBody, "Saber" )
})

local gt = this.getroottable();

if (!("Strings" in gt.Const))
{
    gt.Const.Strings <- {};
}

if (!("World" in gt.Const))
{
    gt.Const.World <- {};
}

if (!("Spawn" in gt.Const.World))
{
    gt.Const.World.Spawn <- {};
}

gt.Const.World.Spawn.Troops.Lindwurm.Cost = 120;
gt.Const.World.Spawn.Troops.BanditMarksmanLOW.Cost = 10;

function onCostCompare( _t1, _t2 )
{
    if (_t1.Cost < _t2.Cost)
    {
        return -1;
    }
    else if (_t1.Cost > _t2.Cost)
    {
        return 1;
    }

    return 0;
}

function calculateCosts( _p )
{
    foreach( p in _p )
    {
        p.Cost <- 0;

        foreach( t in p.Troops )
        {
            p.Cost += t.Type.Cost * t.Num;
        }

        if (!("MovementSpeedMult" in p))
        {
            p.MovementSpeedMult <- 1.0;
        }

        if (!("VisibilityMult" in p))
        {
            p.VisibilityMult <- 1.0;
        }

        if (!("VisionMult" in p))
        {
            p.VisionMult <- 1.0;
        }
    }

    _p.sort(this.onCostCompare);
}

this.calculateCosts(this.Const.World.Spawn.Lindwurm);
this.calculateCosts(this.Const.World.Spawn.BanditRoamers);
this.calculateCosts(this.Const.World.Spawn.BanditScouts);
this.calculateCosts(this.Const.World.Spawn.BanditRaiders);
this.calculateCosts(this.Const.World.Spawn.BanditDefenders);
this.calculateCosts(this.Const.World.Spawn.BanditBoss);
this.calculateCosts(this.Const.World.Spawn.BanditsDisguisedAsDirewolves);

gt.Const.Strings.RumorsTreasureOrcs <- [
    [
        "Караван, перевозивший какие-то ценности, был атакован к %direction% отсюда. Ходят слухи, что у павших переломана каждая кость, а в воздухе висит страшная вонь.",
        "На днях завсегдатай рассказывал о каком-то семейном сокровище, которое он хотел продать. Сказал, что его напугали зеленокожие твари по дороге в город, и он потерял его %terrain% к %direction% отсюда.",
        "На днях путешественник рассказал мне, что видел самого крупного человека в его жизни, а в руках тот держал сундук с сокровищами. Как по мне - выдумки это всё, но если тебе интересно, то парень шёл к %direction% отсюда."
    ],
    [
        "Здоровенный красавчик, ищущий приключений, был здесь пару ночей назад. Отправился к %direction% отсюда, собираясь прикончить парочку зеленокожих. За выпивку он расплатился необычайно красивым самоцветом, которых у него была целая сумка. После этого его больше никто не видел.",
        "Говорят, какой-то знаменитый искатель приключений, забыл, как его имя, однажды украл настоящее сокровище, выполняя очередной контракт. Брехня, как по мне. Вряд ли мы узнаем правду, ведь он был убит орками, которые скрываются где-то %distance% к %direction% отсюда.",
        "Можешь не верить мне на слово, но говорят какие-то здоровенные зелёные уродцы к %direction% отсюда ошиваются с невероятной золотой короной. Ума не приложу, как они её раздобыли.",
        "Зеленокожие разорили несколько поместий одного лорда пару дней назад. Они ушли с огромной горой награбленного. Скорее всего эти зеленокожие ублюдки ушли куда-то к %direction% отсюда."
    ],
    [
        "Встречался с орками? Огромные твари, крепкие, словно быки! Наёмная банда %randommercenarycompany% пару недель назад отравилась к %direction% отсюда, чтобы поохотиться на них. Они так и не вернулись, но их командир был настоящим мешком с деньгами!",
        "О, ты слыхал о коллекции золотых монет сэра Уильяма? Говорят, что она была утрачена века назад, во время последнего вторжения орков. Вроде её видели к %direction% отсюда, но я не знаю подробностей. Сомневаюсь, что это правда.",
        "Какой-то знаменитый оружейник погиб несколько дней назад. Говорят, орки разорили то место, и сбежали с его сбережениями куда-то к %direction% отсюда. Может быть, кто-то ещё сможет рассказать больше.",
        "Хотят слухи, что %randomnoble% заснул вечным сном из-за зеленокожих к %direction% отсюда. Он был знаменит издевательствами над своими слугами, так что никто не будет его здесь оплакивать. Жаль только его золото и драгоценности, которыми он постоянно похвалялся... на них можно было бы купить столько коров и свиней. И куриц!"
    ]
];
gt.Const.Strings.RumorsTreasureGoblins <- [
    [
        "На днях по-настоящему отчаявшийся дворянин рассказал мне, что какие-то вонючие зеленокожие сбежали с его семейной реликвией, отравив сторожевых псов. Он клялся, что они скрылись %terrain% %distance% отсюда, но я не думаю, что ему удастся кого-то убедить пуститься в погоню. Особенно меня.",
